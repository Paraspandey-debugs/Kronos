generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id        String   @id @default(uuid())
  agentType String
  payload   Json
  priority  String   @default("normal")
  status    String   @default("PENDING")
  result    Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String     @id @default(uuid())
  clerkId   String     @unique
  email     String?
  createdAt DateTime   @default(now())
  flows     Flow[]
  workflows Workflow[]
}

model Flow {
  id          String     @id @default(uuid())
  userId      String
  name        String
  description String?
  nodes       Json
  edges       Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  workflows   Workflow[]
}

model Workflow {
  id        String         @id @default(uuid())
  userId    String
  status    String         @default("PENDING")
  error     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  flowId    String?
  name      String         @default("Untitled Workflow")
  flow      Flow?          @relation(fields: [flowId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  nodes     WorkflowNode[]
}

model WorkflowNode {
  id         String   @id @default(uuid())
  workflowId String
  positionX  Float?
  positionY  Float?
  type       String
  agentType  String?
  config     Json
  stepIndex  Int
  dependsOn  String[] @default([])
  status     String   @default("PENDING")
  result     Json?
  error      String?
  startedAt  DateTime?
  completedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model AgentTemplate {
  id             String   @id @default(uuid())
  type           String   @unique
  label          String
  description    String?
  icon           String?
  defaultPayload Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  configSchema   Json?
  outputSchema   Json?
}
